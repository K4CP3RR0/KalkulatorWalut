<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KalkulatorWalut2.Pomoc"
             Title="Pomoc">
    <Grid Loaded="Grid_Loaded">
        
  
    <VerticalStackLayout>
        <Label 
            Text="Witaj w programie Kalkulator Walut! "
            VerticalOptions="Start" 
            HorizontalOptions="Center" 
            FontSize="Header"
            Margin="15,0,0,15"/>
        <Label
            Text="Aby dokonać obliczeń wybierz walutę z listy po lewej, z której będziesz przeliczać i walutę z listy po prawej, na którą chcesz przelić. Na koniec wpisz kwotę a dostaniesz od razu wynik."
            VerticalOptions="Start"
            HorizontalOptions="Start"
            FontSize="Medium"
            Margin="15,10,15,10"
            />
        <Label
            x:Name="komHej"
            Text=""
            VerticalOptions="Start"
            HorizontalOptions="Center"
            Margin="15,0,0,0"
            FontSize="Large"
            />

    </VerticalStackLayout>
    </Grid>
</ContentPage>